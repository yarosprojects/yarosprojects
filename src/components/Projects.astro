// ejemplo webs
import joanoliveImg from "../../public/projects/joanolive.png";

const { creador, translate, locale } = Astro.props;
const DOMAIN_URL = "yarosprojects.dev";

const GAMES = {
    calculator: {
        id: "calculator",
        name: translate.projects.calculator.name,
        url: `https://calculator.${DOMAIN_URL}`,
        image: calculatorImg.src,
        code_link: "https://github.com/yarosprojects/calculator-yarosprojects",
        description: [
            translate.projects.calculator.paragraph_1,
            translate.projects.calculator.paragraph_2,
        ],
        tecnologies: {
            angular: {
                id: "angular-framework",
                name: "Angular",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/angular/angular-original.svg",
                mainColor: "bg-angular",
            },
            typescript: {
                id: "typescript-framework",
                name: "TypeScript",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg",
                mainColor: "bg-typescript",
            },
            tailwind: {
                id: "tailwindcss-framework",
                name: "TailwindCSS",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg",
                mainColor: "bg-tailwindcss",
            },
        },
    },

    tetris: {
        id: "tetris",
        name: translate.projects.tetris.name,
        url: `https://tetris.${DOMAIN_URL}`,
        image: tetrisImg.src,
        code_link: "https://github.com/yarosprojects/tetris-yarosprojects",
        description: [
            translate.projects.tetris.paragraph_1,
            translate.projects.tetris.paragraph_2,
        ],
        tecnologies: {
            svelte: {
                id: "svelte-framework",
                name: "Svelte",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/svelte/svelte-original.svg",
                mainColor: "bg-svelte",
            },
            typescript: {
                id: "typescript-framework",
                name: "TypeScript",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg",
                mainColor: "bg-typescript",
            },
            tailwind: {
                id: "tailwindcss-framework",
                name: "TailwindCSS",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg",
                mainColor: "bg-tailwindcss",
            },
        },
    },

    snake: {
        id: "snake",
        name: translate.projects.snake.name,
        url: `https://snake.${DOMAIN_URL}`,
        image: snakeImg.src,
        code_link: "https://github.com/yarosprojects/snake-yarosprojects",
        description: [
            translate.projects.snake.paragraph_1,
            translate.projects.snake.paragraph_2,
        ],
        tecnologies: {
            vite: {
                id: "vite-framework",
                name: "Vite",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vitejs/vitejs-original.svg",
                mainColor: "bg-vite",
            },
            svelte: {
                id: "svelte-framework",
                name: "Svelte",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/svelte/svelte-original.svg",
                mainColor: "bg-svelte",
            },
            typescript: {
                id: "typescript-framework",
                name: "TypeScript",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg",
                mainColor: "bg-typescript",
            },
            tailwind: {
                id: "tailwindcss-framework",
                name: "TailwindCSS",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg",
                mainColor: "bg-tailwindcss",
            },
        },
    },
};

const WEBS = {
    joanolive: {
        id: "joanolive",
        name: translate.projects.joanolive.name,
        url: `https://pedidosolive.com`,
        image: joanoliveImg.src,
        code_link: null,
        description: [
            translate.projects.joanolive.paragraph_1,
            translate.projects.joanolive.paragraph_2,
        ],
        tecnologies: {
            astro: {
                id: "astro-framework",
                name: "Astro",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg",
                mainColor: "bg-astro",
            },
            typescript: {
                id: "typescript-framework",
                name: "TypeScript",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg",
                mainColor: "bg-typescript",
            },
            tailwind: {
                id: "tailwindcss-framework",
                name: "TailwindCSS",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg",
                mainColor: "bg-tailwindcss",
            },
            supabase: {
                id: "supabase-framework",
                name: "Supabase",
                image: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/supabase/supabase-original.svg",
                mainColor: "bg-supabase",
            },
        },
    },
};

const SECTIONS = [
    {
        id: "games",
        label: translate.projects.labels.mini_games ?? "Mini juegos",
        items: Object.values(GAMES),
    },
    {
        id: "webs",
        label: translate.projects.labels.webs ?? "Web Pages",
        items: Object.values(WEBS),
    },
];
---

<div
    class="pt-(--header-h) w-full flex justify-center items-center px-2 md:px-0"
>
    <div
        class="w-full max-[235px]:flex-col md:max-w-3xl mx-0 md:mx-auto flex justify-start max-[235px]:items-start items-center flex-row gap-4"
    >
        <i
            class="icon-[gridicons--code] max-[235px]:text-xl text-3xl dark:text-white/80 text-black/80"
        ></i>
        <h1
            class="text-center max-[235px]:text-2xl text-4xl dark:text-white text-black font-bold dark:selection:bg-white dark:selection:text-blue-700 selection:bg-blue-700 selection:text-white"
        >
            {translate.nav.projects}
        </h1>
    </div>
</div>

<div class="flex w-full flex-col px-2 md:px-0">
    <div
        class="w-full md:max-w-3xl mx-0 md:mx-auto flex flex-col gap-10 justify-center items-start my-10"
        id="projects-container"
    >
        {
            SECTIONS.map((section) => (
                <div
                    class="flex flex-col w-full project-section"
                    id={`${section.id}-area`}
                >
                    <button
                        class="section-toggle-button w-full text-left rounded-none py-4 hover:px-4 text-xl flex flex-row justify-between items-center dark:hover:bg-gray-800/80 hover:bg-gray-300 border max-[155px]:text-base max-[155px]:hover:text-sm border-x-transparent border-t-transparent dark:border-b-yellow-500/30 border-b-blue-700 cursor-pointer transition-all group outline-none"
                        data-section={section.id}
                    >
                        <span class="dark:text-white text-black transition-all">
                            {section.label}
                        </span>
                        <i class="icon-[line-md--chevron-right] dark:text-white text-black section-chevron transition-all duration-200" />
                    </button>

                    <div
                        class="section-container overflow-hidden transition-all duration-500"
                        style="height: 0px;"
                        id={`${section.id}-container`}
                    >
                        <div class="section-content w-full flex flex-col gap-25 md:gap-8">
                            {section.items.map((item) => {
                                const {
                                    id,
                                    name,
                                    url,
                                    image,
                                    code_link,
                                    tecnologies,
                                    description,
                                } = item;

                                return (
                                    <div
                                        class="flex flex-col md:flex-row justify-between items-start first-of-type:mt-3  group w-full opacity-0 project-card"
                                        id={`${id}-card`}
                                    >
                                        <div class="m-0 p-0 overflow-hidden rounded-2xl border border-gray-300 dark:border-gray-800 dark:group-hover:border-gray-700 group-hover:border-gray-900 transition-all">
                                            <img
                                                src={image}
                                                alt={`${name} image`}
                                                class="w-auto h-full object-cover transition-transform duration-300 scale-110 group-hover:scale-100"
                                            />
                                        </div>

                                        <div class="flex flex-col justify-start items-start md:items-center px-1 md:px-4 w-full md:min-w-[400px] h-full opacity-0 project-description">
                                            <div class="flex flex-1 flex-col justify-start items-start">
                                                <h3 class="md:mt-0 mt-2 dark:text-yellow-400 text-yellow-600 text-3xl max-[250px]:text-xl max-[170px]:text-base font-extrabold uppercase dark:selection:bg-yellow-500 dark:selection:text-black selection:bg-black selection:text-yellow-500">
                                                    {name}
                                                </h3>

                                                <ul class="flex w-full flex-row flex-wrap justify-start items-center my-2 gap-2">
                                                    {tecnologies &&
                                                        Object.values(
                                                            tecnologies,
                                                        ).map((tecnology) => {
                                                            const {
                                                                name,
                                                                image,
                                                                mainColor,
                                                            } = tecnology;

                                                            return (
                                                                <li
                                                                    class={`rounded-full px-2 py-1 ${mainColor} flex justify-center items-center gap-2`}
                                                                >
                                                                    <img
                                                                        src={
                                                                            image
                                                                        }
                                                                        alt={`${name} framework image`}
                                                                        class="size-4"
                                                                    />
                                                                    <span class="text-white text-base max-[250px]:text-sm md:text-[13px]">
                                                                        {name}
                                                                    </span>
                                                                </li>
                                                            );
                                                        })}
                                                </ul>

                                                <div class="text-white/80 text-base selection:text-black selection:bg-yellow-400 mt-10 md:mt-5">
                                                    {description.map((line) => (
                                                        <p class="mt-2 dark:text-white text-black">
                                                            {line}
                                                        </p>
                                                    ))}
                                                </div>
                                            </div>

                                            <div
                                                class={`flex w-full flex-row ${locale === "ua-UK" ? "max-[360px]:flex-col justify-start max-[360px]:items-start" : "max-[250px]:flex-col justify-start max-[240px]:items-start"} items-center my-3 gap-2`}
                                            >
                                                {code_link && (
                                                    <a
                                                        href={code_link}
                                                        target="_blank"
                                                        class="text-white dark:hover:bg-gray-900/50 hover:bg-gray-200 transition-all px-3 py-2 rounded-xl flex justify-center gap-2 items-center dark:bg-gray-900 bg-gray-100 border dark:border-white/30 dark:hover:border-white/40 hover:border-black/50 border-black/30 dark:drop-shadow-none drop-shadow-md drop-shadow-black/10 group"
                                                    >
                                                        <i class="icon-[line-md--github] dark:group-hover:brightness-125 group-hover:brightness-90 dark:text-white text-black" />
                                                        <span class="dark:text-white text-black max-[240px]:text-sm text-base">
                                                            {
                                                                translate
                                                                    .projects
                                                                    .code_btn
                                                            }
                                                        </span>
                                                    </a>
                                                )}

                                                {url && (
                                                    <a
                                                        href={url}
                                                        target="_blank"
                                                        class="text-white dark:hover:bg-gray-900/50 hover:bg-gray-200 transition-all px-3 py-2 rounded-xl flex justify-center gap-2 items-center dark:bg-gray-900 bg-gray-100 border dark:border-white/30 dark:hover:border-white/40 hover:border-black/50 border-black/30 dark:drop-shadow-none drop-shadow-md drop-shadow-black/10 group"
                                                    >
                                                        <i class="icon-[line-md--link] dark:group-hover:brightness-125 group-hover:brightness-90 dark:text-white text-black" />
                                                        <span class="dark:text-white text-black max-[240px]:text-sm text-base">
                                                            {
                                                                translate
                                                                    .projects
                                                                    .preview
                                                            }
                                                        </span>
                                                    </a>
                                                )}
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</div>

<script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleButtons = document.querySelectorAll(
            ".section-toggle-button",
        );
        const btnClassNames = [
            "dark:bg-gray-900/80",
            "bg-gray-300/50",
            "px-4",
            "rounded-tl-xl",
            "rounded-tr-xl",
        ];

        toggleButtons.forEach((button) => {
            const sectionId = button.dataset.section;
            const container = document.getElementById(`${sectionId}-container`);
            const content = container.querySelector(".section-content");
            const cards = container.querySelectorAll(".project-card");

            let opened = false;

            button.addEventListener("click", function () {
                const height = content.clientHeight;
                opened = !opened;

                this.querySelector(".section-chevron").classList.toggle(
                    "rotate-90",
                );
                btnClassNames.forEach((className) => {
                    this.classList.toggle(className, opened);
                });

                container.style.height = opened ? `${height}px` : "0px";
            });

            const observer = new IntersectionObserver(
                (entries, observe) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("animate-fade-in-up");
                            entry.target
                                .querySelector(".project-description")
                                ?.classList.add("animate-fade-in-left");
                            observe.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.1 },
            );

            cards.forEach((card) => observer.observe(card));
        });
    });
</script>
